{
  "$schema": "https://opencode.ai/config.json",
  // MCP servers configuration
  "mcp": {
    // Neovim MCP server for buffer access and editing (bigcodegen)
    "neovim": {
      "type": "local",
      "command": ["npx", "-y", "mcp-neovim-server"],
      "enabled": true,
      "environment": {
        // Enable shell commands execution through vim
        "ALLOW_SHELL_COMMANDS": "true",
        // Socket path for neovim connection (uses NVIM env var)
        "NVIM_SOCKET_PATH": "{env:NVIM}",
      },
    },
  },
  // Skill permissions for neovim-specific agents:
  // allow neovim skills freely, keep ask for superpowers
  "agent": {
    "z-Direct-Action": {
      "permission": {
        "skill": {
          "using-neovim": "allow",
          "using-quickfix": "allow",
          "using-neovim-lsp": "allow",
          "*": "ask",
        },
      },
    },
    "z-Quick-Answer": {
      "permission": {
        "skill": {
          "using-neovim": "allow",
          "using-quickfix": "allow",
          "using-neovim-lsp": "allow",
          "*": "ask",
        },
      },
    },
  },
}
